# Copy this file to server/.env and fill in your own values.
# server/.env is gitignored so your real credentials never get committed.

# Port the scoreboard server listens on.
PORT=3000

# Postgres connection string for the scoreboard database.
# Example for a local Postgres with a dedicated role + database:
#   createuser orbit_game --pwprompt
#   createdb -O orbit_game orbit_game
DATABASE_URL=postgresql://orbit_game:YOUR_PASSWORD_HERE@127.0.0.1:5432/orbit_game
